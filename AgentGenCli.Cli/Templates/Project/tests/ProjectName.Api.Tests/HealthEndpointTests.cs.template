using System.Net.Http.Json;

using {{ProjectName}}.Common.Models.HealthCheck;

using Microsoft.AspNetCore.Hosting;
using Microsoft.AspNetCore.Mvc.Testing;

namespace {{ProjectName}}.Api.Tests;

public class HealthEndpointTests : IClassFixture<WebApplicationFactory<ApiEntryPoint>>
{
    private readonly WebApplicationFactory<ApiEntryPoint> _factory;

    public HealthEndpointTests(WebApplicationFactory<ApiEntryPoint> factory)
    {
        _factory = factory;
    }

    [Fact]
    public async Task Health_returns_health_check_report()
    {
        var client = _factory
            .WithWebHostBuilder(builder => builder.UseEnvironment("E2ETest"))
            .CreateClient();

        var response = await client.GetAsync("/health");
        response.EnsureSuccessStatusCode();

        var report = await response.Content.ReadFromJsonAsync<HealthCheckReport>();
        Assert.NotNull(report);
        Assert.Equal(HealthStatus.Healthy, report.Status);
        Assert.NotEmpty(report.Results);
    }
}
