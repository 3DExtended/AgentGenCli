using {{ProjectName}}.Common.Data;
using {{ProjectName}}.Common.Tests.Testing;
using {{ProjectName}}.Features.{{FeatureName}};
using {{ProjectName}}.Features.{{FeatureName}}.Contracts;
using {{ProjectName}}.Features.{{FeatureName}}.QueryHandlers;
using {{ProjectName}}.Features.{{FeatureName}}.Tests.Testing;

namespace {{ProjectName}}.Features.{{FeatureName}}.Tests.QueryHandlers;

public class Get{{FeatureName}}QueryHandlerTests
{
    [Fact]
    public async Task RunQueryAsync_WhenEntityExists_ReturnsMappedDto()
    {
        await using var scope = new InMemoryFeatureTestScope<{{ProjectName}}DbContext, {{FeatureName}}MapsterConfig>(
            typeof(Get{{FeatureName}}QueryHandler).Assembly
        );
        await scope.EnsureCreatedAsync();

        await using var seedContext = await scope.CreateDbContextAsync();
        var (id, _) = await {{FeatureName}}TestData.SeedAsync(seedContext);

        var handler = scope.GetHandler<Get{{FeatureName}}QueryHandler>();
        var result = await handler.RunQueryAsync(
            new Get{{FeatureName}}Query { ModelId = id },
            CancellationToken.None
        );

        QueryHandlerResultAssert.AssertSome(
            result,
            dto =>
            {
                Assert.Equal(id, dto.Id);
                Assert.Equal({{FeatureName}}TestData.SampleName, dto.Name);
            }
        );
    }

    [Fact]
    public async Task RunQueryAsync_WhenEntityMissing_ReturnsNone()
    {
        await using var scope = new InMemoryFeatureTestScope<{{ProjectName}}DbContext, {{FeatureName}}MapsterConfig>(
            typeof(Get{{FeatureName}}QueryHandler).Assembly
        );
        await scope.EnsureCreatedAsync();

        var handler = scope.GetHandler<Get{{FeatureName}}QueryHandler>();
        var result = await handler.RunQueryAsync(
            new Get{{FeatureName}}Query { ModelId = {{FeatureName}}Id.From(Guid.NewGuid()) },
            CancellationToken.None
        );

        QueryHandlerResultAssert.AssertNone(result);
    }
}
