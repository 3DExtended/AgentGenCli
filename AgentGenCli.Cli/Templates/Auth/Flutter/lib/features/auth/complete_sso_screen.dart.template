import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:go_router/go_router.dart';
import 'package:{{ProjectNameSnake}}/features/auth/auth_provider.dart';

class CompleteSsoScreen extends ConsumerStatefulWidget {
  const CompleteSsoScreen({super.key, this.registrationToken});

  final String? registrationToken;

  @override
  ConsumerState<CompleteSsoScreen> createState() => _CompleteSsoScreenState();
}

class _CompleteSsoScreenState extends ConsumerState<CompleteSsoScreen> {
  final _usernameController = TextEditingController();
  String? _error;
  bool _loading = false;

  @override
  void dispose() {
    _usernameController.dispose();
    super.dispose();
  }

  Future<void> _submit() async {
    final token = widget.registrationToken;
    if (token == null || token.isEmpty) {
      setState(() => _error = 'Missing registration token');
      return;
    }

    setState(() {
      _loading = true;
      _error = null;
    });

    try {
      await ref.read(authNotifierProvider).completeSsoRegistration(
            username: _usernameController.text.trim(),
            registrationToken: token,
          );
    } catch (error) {
      setState(() => _error = error.toString());
    } finally {
      if (mounted) {
        setState(() => _loading = false);
      }
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text('Complete sign-in')),
      body: Padding(
        padding: const EdgeInsets.all(24),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.stretch,
          children: [
            const Text('Choose a username to finish creating your account.'),
            const SizedBox(height: 16),
            TextField(
              controller: _usernameController,
              decoration: const InputDecoration(labelText: 'Username'),
            ),
            if (_error != null) ...[
              const SizedBox(height: 12),
              Text(_error!, style: TextStyle(color: Theme.of(context).colorScheme.error)),
            ],
            const SizedBox(height: 24),
            FilledButton(
              onPressed: _loading ? null : _submit,
              child: Text(_loading ? 'Saving…' : 'Continue'),
            ),
            TextButton(
              onPressed: _loading ? null : () => context.go('/login'),
              child: const Text('Cancel'),
            ),
          ],
        ),
      ),
    );
  }
}
