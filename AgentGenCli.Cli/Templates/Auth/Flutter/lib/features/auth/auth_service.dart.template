import 'dart:convert';

import 'package:google_sign_in/google_sign_in.dart';
import 'package:http/http.dart' as http;
import 'package:sign_in_with_apple/sign_in_with_apple.dart';
import 'package:{{ProjectNameSnake}}/core/api/api_connector.dart';
import 'package:{{ProjectNameSnake}}/core/constants.dart';

class AuthService {
  AuthService(this._apiConnector);

  final ApiConnector _apiConnector;

  Future<String> login({required String username, required String password}) async {
    final response = await http.post(
      Uri.parse('$apiBaseUrl/signin/login'),
      headers: const {'Content-Type': 'application/json'},
      body: jsonEncode({'username': username, 'password': password}),
    );

    if (response.statusCode != 200) {
      throw Exception('Login failed (${response.statusCode})');
    }

    return _unwrapToken(response.body);
  }

  Future<String> register({
    required String username,
    required String email,
    required String password,
  }) async {
    final response = await http.post(
      Uri.parse('$apiBaseUrl/register/register'),
      headers: const {'Content-Type': 'application/json'},
      body: jsonEncode({
        'username': username,
        'email': email,
        'password': password,
      }),
    );

    if (response.statusCode == 409) {
      throw Exception('Username or email already taken');
    }

    if (response.statusCode != 200) {
      throw Exception('Registration failed (${response.statusCode})');
    }

    return _unwrapToken(response.body);
  }

  Future<String> completeSsoRegistration({
    required String username,
    required String registrationToken,
  }) async {
    final response = await http.post(
      Uri.parse('$apiBaseUrl/register/openprovider'),
      headers: const {'Content-Type': 'application/json'},
      body: jsonEncode({
        'username': username,
        'registrationToken': registrationToken,
      }),
    );

    if (response.statusCode == 409) {
      throw Exception('Username or email already taken');
    }

    if (response.statusCode != 200) {
      throw Exception('SSO registration failed (${response.statusCode})');
    }

    return _unwrapToken(response.body);
  }

  Future<String?> signInWithGoogle() async {
    final googleSignIn = GoogleSignIn(scopes: const ['email']);
    final account = await googleSignIn.signIn();
    if (account == null) {
      return null;
    }

    final auth = await account.authentication;
    final idToken = auth.idToken;
    if (idToken == null) {
      throw Exception('Google sign-in did not return an ID token');
    }

    return _providerSignIn(
      path: '/signin/google',
      body: {'identityToken': idToken},
    );
  }

  Future<String?> signInWithApple() async {
    final credential = await SignInWithApple.getAppleIDCredential(
      scopes: [
        AppleIDAuthorizationScopes.email,
        AppleIDAuthorizationScopes.fullName,
      ],
    );

    return _providerSignIn(
      path: '/signin/apple',
      body: {'identityToken': credential.identityToken},
    );
  }

  Future<String?> _providerSignIn({
    required String path,
    required Map<String, dynamic> body,
  }) async {
    final response = await http.post(
      Uri.parse('$apiBaseUrl$path'),
      headers: const {'Content-Type': 'application/json'},
      body: jsonEncode(body),
    );

    if (response.statusCode != 200) {
      throw Exception('Provider sign-in failed (${response.statusCode})');
    }

    final result = _unwrapToken(response.body);
    if (result.startsWith('redirect')) {
      return result.replaceFirst('redirect', '');
    }

    await _apiConnector.setJwt(result);
    return null;
  }

  Future<void> requestPasswordReset({
    required String username,
    required String email,
  }) async {
    final response = await http.post(
      Uri.parse('$apiBaseUrl/signin/requestresetpassword'),
      headers: const {'Content-Type': 'application/json'},
      body: jsonEncode({'username': username, 'email': email}),
    );

    if (response.statusCode != 200) {
      throw Exception('Password reset request failed (${response.statusCode})');
    }
  }

  Future<void> resetPassword({
    required String username,
    required String email,
    required String resetCode,
    required String newPassword,
  }) async {
    final response = await http.post(
      Uri.parse('$apiBaseUrl/signin/resetpassword'),
      headers: const {'Content-Type': 'application/json'},
      body: jsonEncode({
        'username': username,
        'email': email,
        'resetCode': resetCode,
        'newPassword': newPassword,
      }),
    );

    if (response.statusCode != 200) {
      throw Exception('Password reset failed (${response.statusCode})');
    }
  }

  String _unwrapToken(String body) {
    final trimmed = body.trim();
    if (trimmed.startsWith('"') && trimmed.endsWith('"')) {
      return jsonDecode(trimmed) as String;
    }

    return trimmed;
  }
}
